# Environment Variables — Single .env file for entire monorepo
# Copy this file to .env in the root directory

# =====================
# API Configuration
# =====================
# Supabase Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Cloudinary (Image Storage)
# Get your credentials from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Paystack Payment
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@macrostar.ng
ADMIN_EMAIL=admin@macrostar.ng

# Production URLs (set after deployment)
STORE_URL=https://your-store.vercel.app
ADMIN_URL=https://your-admin.vercel.app
API_URL=https://your-api.vercel.app

# =====================
# Store & Admin Configuration
# =====================
# API URL for store and admin apps
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
