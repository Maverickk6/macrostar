# Environment Variables — Copy to .env.local in each app

# =====================
# apps/api
# =====================
DATABASE_URL=postgresql://postgres:password@localhost:5432/macrostar
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
PORT=4000

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# Uploads
UPLOAD_DIR=./uploads

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@macrostar.ng
ADMIN_EMAIL=admin@macrostar.ng

# =====================
# apps/store
# =====================
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# =====================
# apps/admin
# =====================
NEXT_PUBLIC_API_URL=http://localhost:4000
